# Copier en .env sur le Pi (jamais commité — voir .gitignore) et remplir.

# Authentification de la page /docker (docker-compose.prod.yml, service back).
# Ces routes révèlent les noms des projets hébergés sur le Pi, contrairement
# au reste du dashboard (CPU/RAM/disque) qui reste public. Vérifiée par
# l'application elle-même (session par cookie signé, back/src/auth.ts) —
# fonctionne même si on tape directement le port du back, contrairement à un
# Basic Auth vérifié uniquement par Traefik.

# Secret de signature des cookies de session — une longue chaîne aléatoire.
#   openssl rand -hex 32
SESSION_SECRET=

# Hash bcrypt du mot de passe de connexion.
#   node -e "console.log(require('bcryptjs').hashSync('TON_MOT_DE_PASSE', 10))"
DOCKER_PAGE_PASSWORD_HASH=
